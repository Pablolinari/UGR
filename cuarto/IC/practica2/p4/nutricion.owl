<?xml version="1.0"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl  "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd  "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdf  "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY nut  "http://www.semanticweb.org/ic/nutricion#" >
]>

<rdf:RDF xmlns="http://www.semanticweb.org/ic/nutricion#"
     xml:base="http://www.semanticweb.org/ic/nutricion"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:nut="http://www.semanticweb.org/ic/nutricion#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/ic/nutricion">
        <rdfs:comment xml:lang="es">Ontologia de un centro de nutricion web que recomienda
recetas a los clientes en funcion de su perfil (dieta que sigue, tipo de plato que
prioriza, ingredientes obligatorios y alergias).
Practica 2 de Ingenieria del Conocimiento. Autor: Pablo Linari Perez.</rdfs:comment>
        <rdfs:label xml:lang="es">Ontologia Centro de Nutricion</rdfs:label>
    </owl:Ontology>

    <rdfs:Datatype rdf:about="&nut;Edad">
        <rdfs:label xml:lang="es">Edad</rdfs:label>
        <rdfs:comment xml:lang="es">Entero entre 0 y 120 anios.</rdfs:comment>
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;integer"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="&xsd;integer">0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="&xsd;integer">120</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>

    <rdfs:Datatype rdf:about="&nut;Calorias">
        <rdfs:label xml:lang="es">Calorias</rdfs:label>
        <rdfs:comment xml:lang="es">Entero no negativo (kcal).</rdfs:comment>
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;integer"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="&xsd;integer">0</xsd:minInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>

    <rdfs:Datatype rdf:about="&nut;Gramos">
        <rdfs:label xml:lang="es">Gramos</rdfs:label>
        <rdfs:comment xml:lang="es">Decimal no negativo (gramos de macronutriente por 100g).</rdfs:comment>
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="&xsd;decimal">0.0</xsd:minInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>

    <rdfs:Datatype rdf:about="&nut;Sexo">
        <rdfs:label xml:lang="es">Sexo</rdfs:label>
        <rdfs:comment xml:lang="es">Cadena enumerada: Hombre o Mujer.</rdfs:comment>
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:first rdf:datatype="&xsd;string">Hombre</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:first rdf:datatype="&xsd;string">Mujer</rdf:first>
                                <rdf:rest rdf:resource="&rdf;nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>

    <owl:ObjectProperty rdf:about="&nut;tieneIngrediente">
        <rdfs:label xml:lang="es">tiene ingrediente</rdfs:label>
        <rdfs:comment xml:lang="es">Ingredientes que componen una receta.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&nut;Ingrediente"/>
        <owl:inverseOf rdf:resource="&nut;esIngredienteDe"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;esIngredienteDe">
        <rdfs:label xml:lang="es">es ingrediente de</rdfs:label>
        <rdfs:comment xml:lang="es">Inversa de tiene ingrediente.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Receta"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;tieneTipoPlato">
        <rdfs:label xml:lang="es">tiene tipo de plato</rdfs:label>
        <rdfs:comment xml:lang="es">Categoria de plato de la receta: entrante, principal o postre.</rdfs:comment>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&nut;TipoPlato"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;aptaParaDieta">
        <rdfs:label xml:lang="es">apta para dieta</rdfs:label>
        <rdfs:comment xml:lang="es">Tipos de dieta para los que la receta es adecuada.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&nut;Dieta"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;sigueDieta">
        <rdfs:label xml:lang="es">sigue dieta</rdfs:label>
        <rdfs:comment xml:lang="es">Dieta que sigue el cliente.</rdfs:comment>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;Dieta"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;priorizaTipoPlato">
        <rdfs:label xml:lang="es">prioriza tipo de plato</rdfs:label>
        <rdfs:comment xml:lang="es">Tipo de plato que el cliente prioriza en las recomendaciones.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;TipoPlato"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;ingredienteObligatorio">
        <rdfs:label xml:lang="es">ingrediente obligatorio</rdfs:label>
        <rdfs:comment xml:lang="es">Ingrediente que el cliente exige que aparezca en sus recetas.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;Ingrediente"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;tieneAlergia">
        <rdfs:label xml:lang="es">tiene alergia</rdfs:label>
        <rdfs:comment xml:lang="es">Alergias o intolerancias del cliente.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;Alergeno"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;contieneAlergeno">
        <rdfs:label xml:lang="es">contiene alergeno</rdfs:label>
        <rdfs:comment xml:lang="es">Alergeno presente en un ingrediente.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Alergeno"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&nut;recetaContieneAlergeno">
        <rdfs:label xml:lang="es">receta contiene alergeno</rdfs:label>
        <rdfs:comment xml:lang="es">Alergenos presentes en una receta, deducidos de los alergenos de sus ingredientes mediante una cadena de propiedades.</rdfs:comment>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&nut;Alergeno"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&nut;tieneIngrediente"/>
            <rdf:Description rdf:about="&nut;contieneAlergeno"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="&nut;nombre">
        <rdfs:label xml:lang="es">nombre</rdfs:label>
        <rdfs:comment xml:lang="es">Nombre identificativo. Slot comun a varias clases.</rdfs:comment>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;sexo">
        <rdfs:label xml:lang="es">sexo</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;Sexo"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;edad">
        <rdfs:label xml:lang="es">edad</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Cliente"/>
        <rdfs:range rdf:resource="&nut;Edad"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;descripcion">
        <rdfs:label xml:lang="es">descripcion</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;link">
        <rdfs:label xml:lang="es">link</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&xsd;anyURI"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;tiempoPreparacionMin">
        <rdfs:label xml:lang="es">tiempo de preparacion (min)</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;comensales">
        <rdfs:label xml:lang="es">comensales</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;likes">
        <rdfs:label xml:lang="es">likes</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Receta"/>
        <rdfs:range rdf:resource="&xsd;nonNegativeInteger"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;calorias">
        <rdfs:label xml:lang="es">calorias (por 100g)</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Calorias"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;proteinas">
        <rdfs:label xml:lang="es">proteinas (g/100g)</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Gramos"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;grasas">
        <rdfs:label xml:lang="es">grasas (g/100g)</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Gramos"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&nut;carbohidratos">
        <rdfs:label xml:lang="es">carbohidratos (g/100g)</rdfs:label>
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&nut;Ingrediente"/>
        <rdfs:range rdf:resource="&nut;Gramos"/>
    </owl:DatatypeProperty>

    <owl:Class rdf:about="&nut;Cliente">
        <rdfs:label xml:lang="es">Cliente</rdfs:label>
        <rdfs:comment xml:lang="es">Usuario del centro de nutricion. Todo cliente sigue exactamente una dieta.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&nut;sigueDieta"/>
                <owl:someValuesFrom rdf:resource="&nut;Dieta"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&nut;sigueDieta"/>
                <owl:maxCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="&nut;Receta">
        <rdfs:label xml:lang="es">Receta</rdfs:label>
        <rdfs:comment xml:lang="es">Plato recomendable. Toda receta tiene al menos un ingrediente y un unico tipo de plato.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&nut;tieneIngrediente"/>
                <owl:someValuesFrom rdf:resource="&nut;Ingrediente"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&nut;tieneTipoPlato"/>
                <owl:someValuesFrom rdf:resource="&nut;TipoPlato"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="&nut;Ingrediente">
        <rdfs:label xml:lang="es">Ingrediente</rdfs:label>
        <rdfs:comment xml:lang="es">Alimento basico que compone las recetas, con su informacion nutricional.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&nut;calorias"/>
                <owl:someValuesFrom rdf:resource="&nut;Calorias"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="&nut;TipoPlato">
        <rdfs:label xml:lang="es">Tipo de Plato</rdfs:label>
        <rdfs:comment xml:lang="es">Categoria del plato dentro del menu.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Entrante"/>
                    <rdf:Description rdf:about="&nut;Principal"/>
                    <rdf:Description rdf:about="&nut;Postre"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;Dieta">
        <rdfs:label xml:lang="es">Dieta</rdfs:label>
        <rdfs:comment xml:lang="es">Regimen alimentario.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Vegana"/>
                    <rdf:Description rdf:about="&nut;Vegetariana"/>
                    <rdf:Description rdf:about="&nut;Normal"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;Alergeno">
        <rdfs:label xml:lang="es">Alergeno</rdfs:label>
        <rdfs:comment xml:lang="es">Sustancia que puede provocar alergia o intolerancia.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Lactosa"/>
                    <rdf:Description rdf:about="&nut;Gluten"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="&nut;Cliente"/>
            <rdf:Description rdf:about="&nut;Receta"/>
            <rdf:Description rdf:about="&nut;Ingrediente"/>
            <rdf:Description rdf:about="&nut;TipoPlato"/>
            <rdf:Description rdf:about="&nut;Dieta"/>
            <rdf:Description rdf:about="&nut;Alergeno"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:Class rdf:about="&nut;RecetaVegana">
        <rdfs:label xml:lang="es">Receta Vegana</rdfs:label>
        <rdfs:comment xml:lang="es">Receta apta para la dieta vegana.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Receta"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;aptaParaDieta"/>
                        <owl:hasValue rdf:resource="&nut;Vegana"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;RecetaPostre">
        <rdfs:label xml:lang="es">Receta Postre</rdfs:label>
        <rdfs:comment xml:lang="es">Receta cuyo tipo de plato es postre.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Receta"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;tieneTipoPlato"/>
                        <owl:hasValue rdf:resource="&nut;Postre"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;RecetaRapida">
        <rdfs:label xml:lang="es">Receta Rapida</rdfs:label>
        <rdfs:comment xml:lang="es">Receta que se prepara en 15 minutos o menos.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Receta"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;tiempoPreparacionMin"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="&xsd;integer">15</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;RecetaPopular">
        <rdfs:label xml:lang="es">Receta Popular</rdfs:label>
        <rdfs:comment xml:lang="es">Receta con 100 likes o mas.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Receta"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;likes"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="&xsd;integer">100</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;ClienteVegano">
        <rdfs:label xml:lang="es">Cliente Vegano</rdfs:label>
        <rdfs:comment xml:lang="es">Cliente que sigue una dieta vegana.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Cliente"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;sigueDieta"/>
                        <owl:hasValue rdf:resource="&nut;Vegana"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;IngredienteProteico">
        <rdfs:label xml:lang="es">Ingrediente Proteico</rdfs:label>
        <rdfs:comment xml:lang="es">Ingrediente con 20g o mas de proteina por cada 100g.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Ingrediente"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;proteinas"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="&xsd;decimal">20.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:Class rdf:about="&nut;RecetaConLactosa">
        <rdfs:label xml:lang="es">Receta Con Lactosa</rdfs:label>
        <rdfs:comment xml:lang="es">Receta que contiene algun ingrediente con lactosa.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&nut;Receta"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&nut;recetaContieneAlergeno"/>
                        <owl:hasValue rdf:resource="&nut;Lactosa"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:NamedIndividual rdf:about="&nut;Entrante">
        <rdf:type rdf:resource="&nut;TipoPlato"/>
        <nombre>Entrante</nombre>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="&nut;Principal">
        <rdf:type rdf:resource="&nut;TipoPlato"/>
        <nombre>Principal</nombre>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="&nut;Postre">
        <rdf:type rdf:resource="&nut;TipoPlato"/>
        <nombre>Postre</nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&nut;Vegana">
        <rdf:type rdf:resource="&nut;Dieta"/>
        <nombre>Vegana</nombre>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="&nut;Vegetariana">
        <rdf:type rdf:resource="&nut;Dieta"/>
        <nombre>Vegetariana</nombre>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="&nut;Normal">
        <rdf:type rdf:resource="&nut;Dieta"/>
        <nombre>Normal</nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&nut;Lactosa">
        <rdf:type rdf:resource="&nut;Alergeno"/>
        <nombre>Lactosa</nombre>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="&nut;Gluten">
        <rdf:type rdf:resource="&nut;Alergeno"/>
        <nombre>Gluten</nombre>
