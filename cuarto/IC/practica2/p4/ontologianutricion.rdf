    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Alergeno"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Cliente"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Dieta"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Ingrediente"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Receta"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#TipoPlato"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDifferent"/>
        <owl:distinctMembers rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Ana"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#BatidoProteico"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#EnsaladaDeQuinoa"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Juan"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Leche"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#PechugaPollo"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Platano"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#PolloAlHorno"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Quinoa"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#TartaDeChocolate"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Tofu"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/ic/nutricion#Tomate"/>
        </owl:distinctMembers>
